# ============================================================
# AFFILIATE STORE — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# Supabase (get from https://supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=DealZone
NEXT_PUBLIC_APP_DESCRIPTION=Best deals on trending products

# Admin (change this before going live!)
ADMIN_SECRET_KEY=change-this-secret-key

# Optional: Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
